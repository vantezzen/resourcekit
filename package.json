{
  "name": "resourcekit",
  "version": "0.0.0",
  "type": "module",
  "sideEffects": false,
  "workspaces": [
    "playground"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./drizzle": {
      "types": "./dist/adapters/drizzle/index.d.ts",
      "import": "./dist/adapters/drizzle/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "bun --cwd playground dev",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "dexie": "^4.4.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "prettier": "3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "typescript": "^6.0.3",
    "react": ">=18",
    "drizzle-orm": ">=0.36.0",
    "dexie": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "dexie": {
      "optional": true
    }
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
