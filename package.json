{
  "name": "resourcekit",
  "version": "1.0.0",
  "description": "A full-stack data runtime for TypeScript apps: typed resources, instant local reads, optimistic writes with offline replay, and one sync endpoint - on top of your existing backend.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vantezzen/resourcekit.git"
  },
  "author": "vantezzen",
  "keywords": [
    "local-first",
    "sync",
    "offline",
    "optimistic-updates",
    "cache",
    "react",
    "typescript",
    "drizzle"
  ],
  "type": "module",
  "sideEffects": false,
  "workspaces": [
    "playground",
    "docs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./drizzle": {
      "types": "./dist/adapters/drizzle/index.d.ts",
      "import": "./dist/adapters/drizzle/index.js"
    },
    "./memory": {
      "types": "./dist/adapters/memory/index.d.ts",
      "import": "./dist/adapters/memory/index.js"
    },
    "./sqlite": {
      "types": "./dist/adapters/sqlite/index.d.ts",
      "import": "./dist/adapters/sqlite/index.js"
    },
    "./mongo": {
      "types": "./dist/adapters/mongo/index.d.ts",
      "import": "./dist/adapters/mongo/index.js"
    },
    "./redis": {
      "types": "./dist/adapters/redis/index.d.ts",
      "import": "./dist/adapters/redis/index.js"
    },
    "./prisma": {
      "types": "./dist/adapters/prisma/index.d.ts",
      "import": "./dist/adapters/prisma/index.js"
    },
    "./stripe": {
      "types": "./dist/adapters/stripe/index.d.ts",
      "import": "./dist/adapters/stripe/index.js"
    },
    "./stripe/resources": {
      "types": "./dist/adapters/stripe/resources.d.ts",
      "import": "./dist/adapters/stripe/resources.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "TECH.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "DEBUG=resourcekit:* bun --cwd playground dev",
    "docs:dev": "bun --cwd docs run dev",
    "docs:build": "bun --cwd docs run build",
    "build": "tsup",
    "typecheck": "tsc --noEmit && tsc -p playground --noEmit",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "release": "bun run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.3.14",
    "@types/debug": "^4.1.13",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "prettier": "3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "stripe": "^22.2.2",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "vite": "^8.0.16"
  },
  "peerDependencies": {
    "typescript": "^6.0.3",
    "react": ">=18",
    "drizzle-orm": ">=0.36.0",
    "stripe": ">=15"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "stripe": {
      "optional": true
    }
  },
  "dependencies": {
    "debug": "^4.4.3",
    "zod": "^4.4.3"
  }
}
